<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ums_pathway_list" model="ir.ui.view">
        <field name="name">ums.pathway.list</field>
        <field name="model">ums.pathway</field>
        <field name="arch" type="xml">
            <list string="Learning Pathways">
                <field name="name"/>
                <field name="program_id"/>
                <field name="level"/>
                <field name="step_count"/>
            </list>
        </field>
    </record>

    <record id="view_ums_pathway_form" model="ir.ui.view">
        <field name="name">ums.pathway.form</field>
        <field name="model">ums.pathway</field>
        <field name="arch" type="xml">
            <form string="Learning Pathway">
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="program_id"/>
                            <field name="level"/>
                        </group>
                    </group>
                    <field name="description"/>
                    <separator string="Steps"/>
                    <field name="step_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="course_id"/>
                            <field name="content_url"/>
                            <field name="estimated_hours"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ums_pathway" model="ir.actions.act_window">
        <field name="name">Learning Pathways</field>
        <field name="res_model">ums.pathway</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
