<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ums_timeslot_list" model="ir.ui.view">
        <field name="name">ums.timeslot.list</field>
        <field name="model">ums.timeslot</field>
        <field name="arch" type="xml">
            <list string="Time Slots" editable="bottom">
                <field name="dayofweek"/>
                <field name="hour_from" widget="float_time"/>
                <field name="hour_to" widget="float_time"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="action_ums_timeslot" model="ir.actions.act_window">
        <field name="name">Time Slots</field>
        <field name="res_model">ums.timeslot</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
