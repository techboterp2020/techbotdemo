<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ums_room_list" model="ir.ui.view">
        <field name="name">ums.room.list</field>
        <field name="model">ums.room</field>
        <field name="arch" type="xml">
            <list string="Rooms" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="building"/>
                <field name="room_type"/>
                <field name="capacity"/>
                <field name="exam_capacity"/>
                <field name="gender"/>
            </list>
        </field>
    </record>

    <record id="action_ums_room" model="ir.actions.act_window">
        <field name="name">Rooms</field>
        <field name="res_model">ums.room</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
