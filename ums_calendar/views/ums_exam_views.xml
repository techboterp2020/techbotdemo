<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ums_exam_list" model="ir.ui.view">
        <field name="name">ums.exam.schedule.list</field>
        <field name="model">ums.exam.schedule</field>
        <field name="arch" type="xml">
            <list string="Exam Schedule">
                <field name="course_id"/>
                <field name="section_id"/>
                <field name="exam_type"/>
                <field name="exam_date"/>
                <field name="hijri_display"/>
                <field name="hour_from" widget="float_time"/>
                <field name="hour_to" widget="float_time"/>
                <field name="room_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_ums_exam_form" model="ir.ui.view">
        <field name="name">ums.exam.schedule.form</field>
        <field name="model">ums.exam.schedule</field>
        <field name="arch" type="xml">
            <form string="Exam">
                <header>
                    <button name="action_schedule" type="object" string="Schedule"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="section_id"/>
                            <field name="course_id"/>
                            <field name="exam_type"/>
                            <field name="term_id"/>
                        </group>
                        <group>
                            <field name="exam_date"/>
                            <field name="hijri_display"/>
                            <field name="hour_from" widget="float_time"/>
                            <field name="hour_to" widget="float_time"/>
                            <field name="room_id"/>
                        </group>
                    </group>
                    <separator string="Invigilators"/>
                    <field name="invigilator_ids" widget="many2many_tags"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_ums_exam" model="ir.actions.act_window">
        <field name="name">Exam Schedule</field>
        <field name="res_model">ums.exam.schedule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
