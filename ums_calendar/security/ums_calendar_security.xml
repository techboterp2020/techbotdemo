<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Scheduling officers (timetabling, exams) extend the registrar role. -->
    <record id="ums_group_scheduler" model="res.groups">
        <field name="name">Academic: Scheduling Officer</field>
        <field name="implied_ids" eval="[(4, ref('ums_core.ums_group_dept_head'))]"/>
    </record>

    <record id="ums_core.ums_group_registrar" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('ums_group_scheduler'))]"/>
    </record>

</odoo>
