<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ums_graduation_list" model="ir.ui.view">
        <field name="name">ums.graduation.list</field>
        <field name="model">ums.graduation</field>
        <field name="arch" type="xml">
            <list string="Graduations">
                <field name="student_id"/>
                <field name="program_id"/>
                <field name="term_id"/>
                <field name="final_cgpa"/>
                <field name="classification"/>
                <field name="graduation_date"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_ums_graduation_form" model="ir.ui.view">
        <field name="name">ums.graduation.form</field>
        <field name="model">ums.graduation</field>
        <field name="arch" type="xml">
            <form string="Graduation">
                <header>
                    <button name="action_check_eligibility" type="object"
                            string="Check Eligibility" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_clear" type="object" string="Clear"
                            invisible="state != 'eligible'"/>
                    <button name="action_graduate" type="object" string="Graduate"
                            class="oe_highlight" invisible="state != 'cleared'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="program_id"/>
                            <field name="term_id"/>
                        </group>
                        <group>
                            <field name="final_cgpa"/>
                            <field name="classification"/>
                            <field name="graduation_date"/>
                            <field name="hijri_graduation"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_ums_graduation" model="ir.actions.act_window">
        <field name="name">Graduations</field>
        <field name="res_model">ums.graduation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
