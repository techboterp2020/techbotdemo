<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Graduation congratulations -->
    <record id="mail_template_graduation" model="mail.template">
        <field name="name">Assessment: Graduation Congratulations</field>
        <field name="model_id" ref="ums_assessment.model_ums_graduation"/>
        <field name="subject">🎓 Congratulations on your graduation!</field>
        <field name="email_from">{{ (user.email_formatted or '') }}</field>
        <field name="partner_to">{{ object.student_id.partner_id.id }}</field>
        <field name="auto_delete" eval="False"/>
        <field name="body_html" type="html">
            <div style="font-family:Arial,sans-serif;color:#333;">
                <p>Dear <t t-out="object.student_id.name"/>,</p>
                <p>Congratulations on completing your studies in
                    <strong><t t-out="object.program_id.name_en or ''"/></strong>!</p>
                <ul>
                    <li><strong>Final CGPA:</strong> <t t-out="object.final_cgpa"/></li>
                    <li><strong>Classification:</strong> <t t-out="object.classification or ''"/></li>
                </ul>
                <p>Your official transcript and certificate are now available. We wish
                    you continued success.</p>
                <p style="color:#0b6b5e;">تهانينا بمناسبة تخرجك! نتمنى لك دوام التوفيق.</p>
                <p>Warm regards,<br/>Office of the Registrar</p>
            </div>
        </field>
    </record>

</odoo>
