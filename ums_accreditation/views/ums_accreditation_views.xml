<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ums_accreditation_list" model="ir.ui.view">
        <field name="name">ums.accreditation.report.list</field>
        <field name="model">ums.accreditation.report</field>
        <field name="arch" type="xml">
            <list string="Accreditation Reports">
                <field name="name"/>
                <field name="program_id"/>
                <field name="report_type"/>
                <field name="period"/>
                <field name="coverage_percent"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_ums_accreditation_form" model="ir.ui.view">
        <field name="name">ums.accreditation.report.form</field>
        <field name="model">ums.accreditation.report</field>
        <field name="arch" type="xml">
            <form string="Accreditation Report">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="program_id"/>
                            <field name="report_type"/>
                            <field name="period"/>
                        </group>
                        <group>
                            <field name="plo_count"/>
                            <field name="clo_mapped_count"/>
                            <field name="coverage_percent"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ums_accreditation" model="ir.actions.act_window">
        <field name="name">Accreditation Reports</field>
        <field name="res_model">ums.accreditation.report</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
