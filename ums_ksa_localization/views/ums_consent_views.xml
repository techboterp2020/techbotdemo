<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ums_consent_list" model="ir.ui.view">
        <field name="name">ums.consent.list</field>
        <field name="model">ums.consent</field>
        <field name="arch" type="xml">
            <list string="Consent Records">
                <field name="partner_id"/>
                <field name="purpose"/>
                <field name="lawful_basis"/>
                <field name="consent_date"/>
                <field name="expiry_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'given'"
                       decoration-danger="state == 'withdrawn'"
                       decoration-muted="state == 'expired'"/>
            </list>
        </field>
    </record>

    <record id="view_ums_consent_form" model="ir.ui.view">
        <field name="name">ums.consent.form</field>
        <field name="model">ums.consent</field>
        <field name="arch" type="xml">
            <form string="Consent">
                <header>
                    <button name="action_withdraw" type="object" string="Withdraw"
                            invisible="state != 'given'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="given,withdrawn"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="purpose"/>
                            <field name="lawful_basis"/>
                            <field name="source"/>
                        </group>
                        <group>
                            <field name="consent_date"/>
                            <field name="expiry_date"/>
                            <field name="withdrawn_date" invisible="state != 'withdrawn'"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_ums_consent" model="ir.actions.act_window">
        <field name="name">Consent Records</field>
        <field name="res_model">ums.consent</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
