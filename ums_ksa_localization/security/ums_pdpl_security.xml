<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Data Protection Officer — owns PDPL consents and data-subject requests
         (NFR-PRV-01). -->
    <record id="ums_group_dpo" model="res.groups">
        <field name="name">PDPL: Data Protection Officer</field>
        <field name="category_id" ref="ums_core.module_category_ums"/>
        <field name="comment">Manage consent records and data-subject rights requests.</field>
    </record>

    <record id="ums_core.ums_group_admin" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('ums_group_dpo'))]"/>
    </record>

</odoo>
