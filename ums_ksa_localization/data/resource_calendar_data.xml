<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Saudi working week: Sunday–Thursday, Friday–Saturday weekend
         (NFR-LOC-01 / FR-CAL-03). Day-of-week: 0=Mon .. 6=Sun. -->
    <record id="resource_calendar_ksa" model="resource.calendar">
        <field name="name">KSA Standard (Sun–Thu)</field>
        <field name="tz">Asia/Riyadh</field>
        <field name="hours_per_day">8.0</field>
    </record>

    <record id="attendance_sun_am" model="resource.calendar.attendance">
        <field name="name">Sunday Morning</field>
        <field name="calendar_id" ref="resource_calendar_ksa"/>
        <field name="dayofweek">6</field>
        <field name="hour_from">8.0</field>
        <field name="hour_to">12.0</field>
        <field name="day_period">morning</field>
    </record>
    <record id="attendance_sun_pm" model="resource.calendar.attendance">
        <field name="name">Sunday Afternoon</field>
        <field name="calendar_id" ref="resource_calendar_ksa"/>
        <field name="dayofweek">6</field>
        <field name="hour_from">13.0</field>
        <field name="hour_to">17.0</field>
        <field name="day_period">afternoon</field>
    </record>

    <record id="attendance_mon_am" model="resource.calendar.attendance">
        <field name="name">Monday Morning</field>
        <field name="calendar_id" ref="resource_calendar_ksa"/>
        <field name="dayofweek">0</field>
        <field name="hour_from">8.0</field>
        <field name="hour_to">12.0</field>
        <field name="day_period">morning</field>
    </record>
    <record id="attendance_mon_pm" model="resource.calendar.attendance">
        <field name="name">Monday Afternoon</field>
        <field name="calendar_id" ref="resource_calendar_ksa"/>
        <field name="dayofweek">0</field>
        <field name="hour_from">13.0</field>
        <field name="hour_to">17.0</field>
        <field name="day_period">afternoon</field>
    </record>

    <record id="attendance_tue_am" model="resource.calendar.attendance">
        <field name="name">Tuesday Morning</field>
        <field name="calendar_id" ref="resource_calendar_ksa"/>
        <field name="dayofweek">1</field>
        <field name="hour_from">8.0</field>
        <field name="hour_to">12.0</field>
        <field name="day_period">morning</field>
    </record>
    <record id="attendance_tue_pm" model="resource.calendar.attendance">
        <field name="name">Tuesday Afternoon</field>
        <field name="calendar_id" ref="resource_calendar_ksa"/>
        <field name="dayofweek">1</field>
        <field name="hour_from">13.0</field>
        <field name="hour_to">17.0</field>
        <field name="day_period">afternoon</field>
    </record>

    <record id="attendance_wed_am" model="resource.calendar.attendance">
        <field name="name">Wednesday Morning</field>
        <field name="calendar_id" ref="resource_calendar_ksa"/>
        <field name="dayofweek">2</field>
        <field name="hour_from">8.0</field>
        <field name="hour_to">12.0</field>
        <field name="day_period">morning</field>
    </record>
    <record id="attendance_wed_pm" model="resource.calendar.attendance">
        <field name="name">Wednesday Afternoon</field>
        <field name="calendar_id" ref="resource_calendar_ksa"/>
        <field name="dayofweek">2</field>
        <field name="hour_from">13.0</field>
        <field name="hour_to">17.0</field>
        <field name="day_period">afternoon</field>
    </record>

    <record id="attendance_thu_am" model="resource.calendar.attendance">
        <field name="name">Thursday Morning</field>
        <field name="calendar_id" ref="resource_calendar_ksa"/>
        <field name="dayofweek">3</field>
        <field name="hour_from">8.0</field>
        <field name="hour_to">12.0</field>
        <field name="day_period">morning</field>
    </record>
    <record id="attendance_thu_pm" model="resource.calendar.attendance">
        <field name="name">Thursday Afternoon</field>
        <field name="calendar_id" ref="resource_calendar_ksa"/>
        <field name="dayofweek">3</field>
        <field name="hour_from">13.0</field>
        <field name="hour_to">17.0</field>
        <field name="day_period">afternoon</field>
    </record>

</odoo>
