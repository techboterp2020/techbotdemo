<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- =====================================================================
         UMS security-group skeleton. Downstream UMS modules extend these
         groups (Section 4 / NFR-SEC-01).
         Note: Odoo 19 removed res.groups.category_id/comment; groups are
         defined with name + implied_ids only.
         ===================================================================== -->

    <!-- Catalog/structure maintainers: department heads, deans, registrars. -->
    <record id="ums_group_academic_user" model="res.groups">
        <field name="name">Academic: User</field>
    </record>

    <record id="ums_group_dept_head" model="res.groups">
        <field name="name">Academic: Department Head</field>
        <field name="implied_ids" eval="[(4, ref('ums_group_academic_user'))]"/>
    </record>

    <record id="ums_group_registrar" model="res.groups">
        <field name="name">Academic: Registrar</field>
        <field name="implied_ids" eval="[(4, ref('ums_group_dept_head'))]"/>
    </record>

    <record id="ums_group_admin" model="res.groups">
        <field name="name">Academic: System Administrator</field>
        <field name="implied_ids" eval="[(4, ref('ums_group_registrar'))]"/>
    </record>

    <!-- Grant the base admin user the top UMS role on install.
         Odoo 19 renamed res.users.groups_id -> group_ids. -->
    <record id="base.user_admin" model="res.users">
        <field name="group_ids" eval="[(4, ref('ums_group_admin'))]"/>
    </record>

</odoo>
