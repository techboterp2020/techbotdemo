<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Default Saudi 5.0 grading scheme (FR-ACS-07 / FR-ASM-03).
         F = 1.0 points. Editable by the System Administrator after install. -->
    <record id="grade_scheme_saudi_5" model="ums.grade.scheme">
        <field name="code">SA5</field>
        <field name="name_en">Saudi 5.0 Scale</field>
        <field name="name_ar">سلم التقدير السعودي 5.0</field>
        <field name="scale">5</field>
    </record>

    <record id="grade_band_sa5_aplus" model="ums.grade.scheme.line">
        <field name="scheme_id" ref="grade_scheme_saudi_5"/>
        <field name="letter">A+</field>
        <field name="letter_ar">أ+</field>
        <field name="min_mark">95</field>
        <field name="max_mark">100</field>
        <field name="grade_point">5.0</field>
    </record>
    <record id="grade_band_sa5_a" model="ums.grade.scheme.line">
        <field name="scheme_id" ref="grade_scheme_saudi_5"/>
        <field name="letter">A</field>
        <field name="letter_ar">أ</field>
        <field name="min_mark">90</field>
        <field name="max_mark">94.99</field>
        <field name="grade_point">4.75</field>
    </record>
    <record id="grade_band_sa5_bplus" model="ums.grade.scheme.line">
        <field name="scheme_id" ref="grade_scheme_saudi_5"/>
        <field name="letter">B+</field>
        <field name="letter_ar">ب+</field>
        <field name="min_mark">85</field>
        <field name="max_mark">89.99</field>
        <field name="grade_point">4.5</field>
    </record>
    <record id="grade_band_sa5_b" model="ums.grade.scheme.line">
        <field name="scheme_id" ref="grade_scheme_saudi_5"/>
        <field name="letter">B</field>
        <field name="letter_ar">ب</field>
        <field name="min_mark">80</field>
        <field name="max_mark">84.99</field>
        <field name="grade_point">4.0</field>
    </record>
    <record id="grade_band_sa5_cplus" model="ums.grade.scheme.line">
        <field name="scheme_id" ref="grade_scheme_saudi_5"/>
        <field name="letter">C+</field>
        <field name="letter_ar">ج+</field>
        <field name="min_mark">75</field>
        <field name="max_mark">79.99</field>
        <field name="grade_point">3.5</field>
    </record>
    <record id="grade_band_sa5_c" model="ums.grade.scheme.line">
        <field name="scheme_id" ref="grade_scheme_saudi_5"/>
        <field name="letter">C</field>
        <field name="letter_ar">ج</field>
        <field name="min_mark">70</field>
        <field name="max_mark">74.99</field>
        <field name="grade_point">3.0</field>
    </record>
    <record id="grade_band_sa5_dplus" model="ums.grade.scheme.line">
        <field name="scheme_id" ref="grade_scheme_saudi_5"/>
        <field name="letter">D+</field>
        <field name="letter_ar">د+</field>
        <field name="min_mark">65</field>
        <field name="max_mark">69.99</field>
        <field name="grade_point">2.5</field>
    </record>
    <record id="grade_band_sa5_d" model="ums.grade.scheme.line">
        <field name="scheme_id" ref="grade_scheme_saudi_5"/>
        <field name="letter">D</field>
        <field name="letter_ar">د</field>
        <field name="min_mark">60</field>
        <field name="max_mark">64.99</field>
        <field name="grade_point">2.0</field>
    </record>
    <record id="grade_band_sa5_f" model="ums.grade.scheme.line">
        <field name="scheme_id" ref="grade_scheme_saudi_5"/>
        <field name="letter">F</field>
        <field name="letter_ar">هـ</field>
        <field name="min_mark">0</field>
        <field name="max_mark">59.99</field>
        <field name="grade_point">1.0</field>
        <field name="is_fail">1</field>
    </record>

</odoo>
