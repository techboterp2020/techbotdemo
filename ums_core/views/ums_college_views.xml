<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ums_college_list" model="ir.ui.view">
        <field name="name">ums.college.list</field>
        <field name="model">ums.college</field>
        <field name="arch" type="xml">
            <list string="Colleges">
                <field name="code"/>
                <field name="name_en"/>
                <field name="name_ar"/>
                <field name="institution_id"/>
                <field name="dean_id"/>
                <field name="department_count"/>
                <field name="program_count"/>
            </list>
        </field>
    </record>

    <record id="view_ums_college_form" model="ir.ui.view">
        <field name="name">ums.college.form</field>
        <field name="model">ums.college</field>
        <field name="arch" type="xml">
            <form string="College">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_departments" type="object"
                                class="oe_stat_button" icon="fa-sitemap">
                            <field name="department_count" widget="statinfo" string="Departments"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name_en" placeholder="Name (English)"/></h1>
                        <h2><field name="name_ar" placeholder="Name (Arabic)"/></h2>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="institution_id"/>
                        </group>
                        <group>
                            <field name="dean_id"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_ums_college_search" model="ir.ui.view">
        <field name="name">ums.college.search</field>
        <field name="model">ums.college</field>
        <field name="arch" type="xml">
            <search>
                <field name="name_en"/>
                <field name="name_ar"/>
                <field name="code"/>
                <field name="institution_id"/>
                <group expand="0" string="Group By">
                    <filter name="group_institution" string="Institution"
                            context="{'group_by': 'institution_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ums_college" model="ir.actions.act_window">
        <field name="name">Colleges</field>
        <field name="res_model">ums.college</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
