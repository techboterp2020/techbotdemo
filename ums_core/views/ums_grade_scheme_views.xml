<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ums_grade_scheme_list" model="ir.ui.view">
        <field name="name">ums.grade.scheme.list</field>
        <field name="model">ums.grade.scheme</field>
        <field name="arch" type="xml">
            <list string="Grade Schemes">
                <field name="code"/>
                <field name="name_en"/>
                <field name="name_ar"/>
                <field name="scale"/>
                <field name="max_points"/>
            </list>
        </field>
    </record>

    <record id="view_ums_grade_scheme_form" model="ir.ui.view">
        <field name="name">ums.grade.scheme.form</field>
        <field name="model">ums.grade.scheme</field>
        <field name="arch" type="xml">
            <form string="Grade Scheme">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name_en" placeholder="Name (English)"/></h1>
                        <h2><field name="name_ar" placeholder="Name (Arabic)"/></h2>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="scale"/>
                        </group>
                        <group>
                            <field name="max_points"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <separator string="Grade Bands"/>
                    <field name="line_ids">
                        <list editable="bottom" default_order="min_mark desc">
                            <field name="letter"/>
                            <field name="letter_ar"/>
                            <field name="min_mark"/>
                            <field name="max_mark"/>
                            <field name="grade_point"/>
                            <field name="is_fail"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ums_grade_scheme" model="ir.actions.act_window">
        <field name="name">Grade Schemes</field>
        <field name="res_model">ums.grade.scheme</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
