<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ums_institution_list" model="ir.ui.view">
        <field name="name">ums.institution.list</field>
        <field name="model">ums.institution</field>
        <field name="arch" type="xml">
            <list string="Institutions">
                <field name="code"/>
                <field name="name_en"/>
                <field name="name_ar"/>
                <field name="college_count"/>
                <field name="program_count"/>
            </list>
        </field>
    </record>

    <record id="view_ums_institution_form" model="ir.ui.view">
        <field name="name">ums.institution.form</field>
        <field name="model">ums.institution</field>
        <field name="arch" type="xml">
            <form string="Institution">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_colleges" type="object"
                                class="oe_stat_button" icon="fa-university">
                            <field name="college_count" widget="statinfo" string="Colleges"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-graduation-cap" disabled="1">
                            <field name="program_count" widget="statinfo" string="Programs"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name_en" string="Institution"/>
                        <h1><field name="name_en" placeholder="Name (English)"/></h1>
                        <h2><field name="name_ar" placeholder="Name (Arabic)"/></h2>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="vat"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_ums_institution" model="ir.actions.act_window">
        <field name="name">Institutions</field>
        <field name="res_model">ums.institution</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create the first institution</p>
            <p>The institution is the top of the academic hierarchy.</p>
        </field>
    </record>

</odoo>
