<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ums_course_list" model="ir.ui.view">
        <field name="name">ums.course.list</field>
        <field name="model">ums.course</field>
        <field name="arch" type="xml">
            <list string="Courses">
                <field name="code"/>
                <field name="name_en"/>
                <field name="name_ar"/>
                <field name="department_id"/>
                <field name="credit_hours" sum="Credit Hours"/>
                <field name="contact_hours"/>
                <field name="level"/>
                <field name="course_type"/>
            </list>
        </field>
    </record>

    <record id="view_ums_course_form" model="ir.ui.view">
        <field name="name">ums.course.form</field>
        <field name="model">ums.course</field>
        <field name="arch" type="xml">
            <form string="Course">
                <sheet>
                    <div class="oe_title">
                        <label for="code"/>
                        <h1><field name="code" placeholder="e.g. CS101"/></h1>
                        <h2><field name="name_en" placeholder="Title (English)"/></h2>
                        <h3><field name="name_ar" placeholder="Title (Arabic)"/></h3>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="department_id"/>
                            <field name="college_id"/>
                            <field name="course_type"/>
                            <field name="level"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="Hours">
                            <field name="credit_hours"/>
                            <field name="lecture_hours"/>
                            <field name="lab_hours"/>
                            <field name="tutorial_hours"/>
                            <field name="contact_hours"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Prerequisites &amp; Equivalencies" name="prereq">
                            <field name="prerequisite_ids">
                                <list editable="bottom">
                                    <field name="relation_type"/>
                                    <field name="prerequisite_course_id"/>
                                    <field name="min_grade_point"/>
                                </list>
                            </field>
                            <separator string="Equivalent Courses"/>
                            <field name="equivalent_course_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Learning Outcomes (CLO)" name="clo">
                            <field name="learning_outcome_ids"
                                   context="{'default_outcome_type': 'clo', 'default_course_id': id}">
                                <list editable="bottom">
                                    <field name="outcome_type" column_invisible="1"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="mapped_plo_ids" widget="many2many_tags"/>
                                </list>
                            </field>
                        </page>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_ums_course_search" model="ir.ui.view">
        <field name="name">ums.course.search</field>
        <field name="model">ums.course</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name_en"/>
                <field name="name_ar"/>
                <field name="department_id"/>
                <group expand="0" string="Group By">
                    <filter name="group_dept" string="Department"
                            context="{'group_by': 'department_id'}"/>
                    <filter name="group_type" string="Type"
                            context="{'group_by': 'course_type'}"/>
                    <filter name="group_level" string="Level"
                            context="{'group_by': 'level'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ums_course" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">ums.course</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
