<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ums_lms_link_list" model="ir.ui.view">
        <field name="name">ums.lms.link.list</field>
        <field name="model">ums.lms.link</field>
        <field name="arch" type="xml">
            <list string="LMS Links">
                <field name="name"/>
                <field name="lms_type"/>
                <field name="standard"/>
                <field name="base_url"/>
                <field name="sync_roster"/>
                <field name="sync_grades"/>
            </list>
        </field>
    </record>

    <record id="view_ums_lms_link_form" model="ir.ui.view">
        <field name="name">ums.lms.link.form</field>
        <field name="model">ums.lms.link</field>
        <field name="arch" type="xml">
            <form string="LMS Link">
                <header>
                    <button name="action_sync_roster" type="object"
                            string="Sync Roster" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="lms_type"/>
                            <field name="standard"/>
                            <field name="base_url"/>
                        </group>
                        <group>
                            <field name="client_id"/>
                            <field name="deployment_id"/>
                            <field name="sync_roster"/>
                            <field name="sync_grades"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ums_lms_link" model="ir.actions.act_window">
        <field name="name">LMS Integration</field>
        <field name="res_model">ums.lms.link</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
