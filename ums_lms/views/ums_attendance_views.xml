<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ums_attendance_session_list" model="ir.ui.view">
        <field name="name">ums.attendance.session.list</field>
        <field name="model">ums.attendance.session</field>
        <field name="arch" type="xml">
            <list string="Attendance Sessions">
                <field name="session_date"/>
                <field name="section_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_ums_attendance_session_form" model="ir.ui.view">
        <field name="name">ums.attendance.session.form</field>
        <field name="model">ums.attendance.session</field>
        <field name="arch" type="xml">
            <form string="Attendance Session">
                <header>
                    <button name="action_load_roster" type="object"
                            string="Load Roster" class="oe_highlight"/>
                    <button name="action_mark_done" type="object" string="Mark Recorded"
                            invisible="state == 'done'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="section_id"/>
                            <field name="session_date"/>
                        </group>
                        <group>
                            <field name="hour_from" widget="float_time"/>
                            <field name="hour_to" widget="float_time"/>
                        </group>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="student_id"/>
                            <field name="status"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ums_attendance_session" model="ir.actions.act_window">
        <field name="name">Attendance</field>
        <field name="res_model">ums.attendance.session</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
