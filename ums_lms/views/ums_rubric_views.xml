<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ums_rubric_form" model="ir.ui.view">
        <field name="name">ums.rubric.form</field>
        <field name="model">ums.rubric</field>
        <field name="arch" type="xml">
            <form string="Rubric">
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <field name="max_score"/>
                    </group>
                    <field name="criterion_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name"/>
                            <field name="max_points"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ums_rubric_list" model="ir.ui.view">
        <field name="name">ums.rubric.list</field>
        <field name="model">ums.rubric</field>
        <field name="arch" type="xml">
            <list string="Rubrics">
                <field name="name"/>
                <field name="max_score"/>
            </list>
        </field>
    </record>

    <record id="action_ums_rubric" model="ir.actions.act_window">
        <field name="name">Rubrics</field>
        <field name="res_model">ums.rubric</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
