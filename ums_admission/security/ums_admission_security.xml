<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ums_group_admissions" model="res.groups">
        <field name="name">Admissions: Officer</field>
        <field name="category_id" ref="ums_core.module_category_ums"/>
        <field name="implied_ids" eval="[(4, ref('ums_core.ums_group_academic_user'))]"/>
        <field name="comment">Manage leads, applications, document verification and offers.</field>
    </record>

    <record id="ums_group_admissions_committee" model="res.groups">
        <field name="name">Admissions: Committee</field>
        <field name="category_id" ref="ums_core.module_category_ums"/>
        <field name="implied_ids" eval="[(4, ref('ums_group_admissions'))]"/>
        <field name="comment">Review, shortlist, issue offers and enroll applicants.</field>
    </record>

    <record id="ums_core.ums_group_registrar" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('ums_group_admissions_committee'))]"/>
    </record>
</odoo>
