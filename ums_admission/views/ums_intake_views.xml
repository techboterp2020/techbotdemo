<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ums_intake_list" model="ir.ui.view">
        <field name="name">ums.intake.list</field>
        <field name="model">ums.intake</field>
        <field name="arch" type="xml">
            <list string="Intakes">
                <field name="code"/>
                <field name="name"/>
                <field name="term_id"/>
                <field name="date_open"/>
                <field name="date_close"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_ums_intake_form" model="ir.ui.view">
        <field name="name">ums.intake.form</field>
        <field name="model">ums.intake</field>
        <field name="arch" type="xml">
            <form string="Intake">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Fall 2026 Intake"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="term_id"/>
                        </group>
                        <group>
                            <field name="date_open"/>
                            <field name="date_close"/>
                            <field name="application_fee"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <separator string="Seat Quotas"/>
                    <field name="quota_ids">
                        <list editable="bottom">
                            <field name="program_id"/>
                            <field name="gender"/>
                            <field name="seats"/>
                            <field name="seats_filled"/>
                            <field name="seats_available"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ums_intake" model="ir.actions.act_window">
        <field name="name">Intakes</field>
        <field name="res_model">ums.intake</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
