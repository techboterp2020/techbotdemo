<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ums_lead_list" model="ir.ui.view">
        <field name="name">ums.lead.list</field>
        <field name="model">ums.lead</field>
        <field name="arch" type="xml">
            <list string="Leads">
                <field name="name"/>
                <field name="program_id"/>
                <field name="intake_id"/>
                <field name="source"/>
                <field name="salesperson_id"/>
                <field name="stage" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_ums_lead_kanban" model="ir.ui.view">
        <field name="name">ums.lead.kanban</field>
        <field name="model">ums.lead</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage">
                <field name="name"/>
                <field name="program_id"/>
                <field name="source"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <strong><field name="name"/></strong>
                            <div><field name="program_id"/></div>
                            <div class="text-muted"><field name="source"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_ums_lead_form" model="ir.ui.view">
        <field name="name">ums.lead.form</field>
        <field name="model">ums.lead</field>
        <field name="arch" type="xml">
            <form string="Lead">
                <header>
                    <button name="action_convert_to_application" type="object"
                            string="Convert to Application" class="oe_highlight"
                            invisible="stage in ('applied','lost')"/>
                    <field name="stage" widget="statusbar"
                           statusbar_visible="new,contacted,qualified,applied"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Prospect name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="national_id"/>
                        </group>
                        <group>
                            <field name="program_id"/>
                            <field name="intake_id"/>
                            <field name="source"/>
                            <field name="salesperson_id"/>
                            <field name="application_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_ums_lead_search" model="ir.ui.view">
        <field name="name">ums.lead.search</field>
        <field name="model">ums.lead</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="program_id"/>
                <group expand="0" string="Group By">
                    <filter name="group_stage" string="Stage" context="{'group_by': 'stage'}"/>
                    <filter name="group_source" string="Source" context="{'group_by': 'source'}"/>
                    <filter name="group_program" string="Program" context="{'group_by': 'program_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ums_lead" model="ir.actions.act_window">
        <field name="name">Leads</field>
        <field name="res_model">ums.lead</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
</odoo>
