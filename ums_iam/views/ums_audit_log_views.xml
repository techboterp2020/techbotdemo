<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ums_audit_log_list" model="ir.ui.view">
        <field name="name">ums.audit.log.list</field>
        <field name="model">ums.audit.log</field>
        <field name="arch" type="xml">
            <list string="Audit Log" create="false" edit="false">
                <field name="log_date"/>
                <field name="user_id"/>
                <field name="category"/>
                <field name="name"/>
                <field name="model_name"/>
                <field name="res_id"/>
            </list>
        </field>
    </record>

    <record id="view_ums_audit_log_form" model="ir.ui.view">
        <field name="name">ums.audit.log.form</field>
        <field name="model">ums.audit.log</field>
        <field name="arch" type="xml">
            <form string="Audit Entry" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="log_date"/>
                            <field name="user_id"/>
                            <field name="category"/>
                        </group>
                        <group>
                            <field name="name"/>
                            <field name="model_name"/>
                            <field name="res_id"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ums_audit_log_search" model="ir.ui.view">
        <field name="name">ums.audit.log.search</field>
        <field name="model">ums.audit.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="user_id"/>
                <field name="model_name"/>
                <group expand="0" string="Group By">
                    <filter name="group_category" string="Category" context="{'group_by': 'category'}"/>
                    <filter name="group_user" string="User" context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ums_audit_log" model="ir.actions.act_window">
        <field name="name">Audit Log</field>
        <field name="res_model">ums.audit.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
