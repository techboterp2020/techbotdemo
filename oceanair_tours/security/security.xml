<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_oceanair_user" model="res.groups">
        <field name="name">Tour Operations / User</field>
    </record>

    <record id="group_oceanair_manager" model="res.groups">
        <field name="name">Tour Operations / Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_oceanair_user'))]"/>
    </record>

    <!-- In this demo every internal user can use the Tours app, so it
         always shows up for whoever is logged in. -->
    <record id="base.group_user" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_oceanair_user'))]"/>
    </record>

</odoo>
