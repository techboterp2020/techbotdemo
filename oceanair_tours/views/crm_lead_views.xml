<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add a "Create Tour Booking" button to the CRM Opportunity form,
         demonstrating the CRM -> Operations hand-off. -->
    <record id="view_crm_lead_form_oceanair" model="ir.ui.view">
        <field name="name">crm.lead.form.oceanair.tours</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_create_tour_booking" type="object"
                        string="Create Tour Booking" class="btn-secondary"/>
            </xpath>
        </field>
    </record>

</odoo>
