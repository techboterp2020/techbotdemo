<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_oceanair_package_list" model="ir.ui.view">
        <field name="name">oceanair.tour.package.list</field>
        <field name="model">oceanair.tour.package</field>
        <field name="arch" type="xml">
            <list string="Tour Packages">
                <field name="code"/>
                <field name="name"/>
                <field name="tour_type"/>
                <field name="destination"/>
                <field name="duration_days"/>
                <field name="default_price"/>
                <field name="booking_count"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_oceanair_package_form" model="ir.ui.view">
        <field name="name">oceanair.tour.package.form</field>
        <field name="model">oceanair.tour.package</field>
        <field name="arch" type="xml">
            <form string="Tour Package">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_bookings" type="object"
                                class="oe_stat_button" icon="fa-suitcase">
                            <field name="booking_count" widget="statinfo"
                                   string="Bookings"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name"
                                   placeholder="e.g. Dubai City Tour"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="tour_type"/>
                            <field name="destination"/>
                        </group>
                        <group>
                            <field name="duration_days"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="default_price"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Itinerary" name="itinerary">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_oceanair_package" model="ir.actions.act_window">
        <field name="name">Tour Packages</field>
        <field name="res_model">oceanair.tour.package</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first tour package
            </p>
            <p>City Tours, Safari, Egypt, Croatia, Domes stays and custom
               packages with a default selling price per passenger.</p>
        </field>
    </record>

</odoo>
