<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ums_credential_list" model="ir.ui.view">
        <field name="name">ums.credential.list</field>
        <field name="model">ums.credential</field>
        <field name="arch" type="xml">
            <list string="Credentials">
                <field name="serial"/>
                <field name="name"/>
                <field name="credential_type"/>
                <field name="student_id"/>
                <field name="issue_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'issued'"
                       decoration-danger="state == 'revoked'"/>
            </list>
        </field>
    </record>

    <record id="view_ums_credential_form" model="ir.ui.view">
        <field name="name">ums.credential.form</field>
        <field name="model">ums.credential</field>
        <field name="arch" type="xml">
            <form string="Credential">
                <header>
                    <button name="action_issue" type="object" string="Issue"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_revoke" type="object" string="Revoke"
                            invisible="state != 'issued'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="serial" readonly="1"/>
                            <field name="credential_type"/>
                            <field name="student_id"/>
                            <field name="program_id"/>
                        </group>
                        <group>
                            <field name="issue_date"/>
                            <field name="expiry_date"/>
                            <field name="verification_token" readonly="1"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_ums_credential" model="ir.actions.act_window">
        <field name="name">Credentials</field>
        <field name="res_model">ums.credential</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
