<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ums_registration_list" model="ir.ui.view">
        <field name="name">ums.registration.list</field>
        <field name="model">ums.registration</field>
        <field name="arch" type="xml">
            <list string="Registrations">
                <field name="student_id"/>
                <field name="course_id"/>
                <field name="section_id"/>
                <field name="term_id"/>
                <field name="credit_hours"/>
                <field name="advisor_approved"/>
                <field name="grade_letter"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('confirmed','completed')"
                       decoration-info="state == 'registered'"
                       decoration-danger="state in ('dropped','withdrawn','failed')"/>
            </list>
        </field>
    </record>

    <record id="view_ums_registration_form" model="ir.ui.view">
        <field name="name">ums.registration.form</field>
        <field name="model">ums.registration</field>
        <field name="arch" type="xml">
            <form string="Registration">
                <header>
                    <button name="action_register" type="object" string="Register"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_confirm" type="object" string="Confirm"
                            invisible="state != 'registered'"/>
                    <button name="action_drop" type="object" string="Drop"
                            invisible="state not in ('registered','confirmed')"/>
                    <button name="action_withdraw" type="object" string="Withdraw"
                            invisible="state not in ('registered','confirmed')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,registered,confirmed,completed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="section_id"/>
                            <field name="course_id"/>
                        </group>
                        <group>
                            <field name="term_id"/>
                            <field name="credit_hours"/>
                            <field name="registration_date"/>
                            <field name="advisor_approved"/>
                        </group>
                    </group>
                    <group string="Result" invisible="state not in ('completed','failed')">
                        <field name="grade_letter"/>
                        <field name="grade_point"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_ums_registration_search" model="ir.ui.view">
        <field name="name">ums.registration.search</field>
        <field name="model">ums.registration</field>
        <field name="arch" type="xml">
            <search>
                <field name="student_id"/>
                <field name="course_id"/>
                <field name="term_id"/>
                <group expand="0" string="Group By">
                    <filter name="group_term" string="Term" context="{'group_by': 'term_id'}"/>
                    <filter name="group_student" string="Student" context="{'group_by': 'student_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ums_registration" model="ir.actions.act_window">
        <field name="name">Registrations</field>
        <field name="res_model">ums.registration</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
