<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ums_student_list" model="ir.ui.view">
        <field name="name">ums.student.list</field>
        <field name="model">ums.student</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="university_id"/>
                <field name="name"/>
                <field name="national_id"/>
                <field name="program_id"/>
                <field name="level"/>
                <field name="gender"/>
                <field name="active_hold_count"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-warning="status in ('leave','suspended')"
                       decoration-danger="status in ('withdrawn','dismissed')"
                       decoration-muted="status == 'graduated'"/>
            </list>
        </field>
    </record>

    <record id="view_ums_student_form" model="ir.ui.view">
        <field name="name">ums.student.form</field>
        <field name="model">ums.student</field>
        <field name="arch" type="xml">
            <form string="Student">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="active,graduated"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_registrations" type="object"
                                class="oe_stat_button" icon="fa-book">
                            <field name="completed_credit_hours" widget="statinfo"
                                   string="Completed CH"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-ban" disabled="1">
                            <field name="active_hold_count" widget="statinfo"
                                   string="Active Holds"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Full name"/></h1>
                        <h3><field name="university_id" readonly="1"/></h3>
                    </div>
                    <group>
                        <group string="Identity">
                            <field name="national_id"/>
                            <field name="gender"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                        <group string="Academic">
                            <field name="program_id"/>
                            <field name="study_plan_id"/>
                            <field name="department_id"/>
                            <field name="advisor_id"/>
                            <field name="admission_term_id"/>
                            <field name="level"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Registrations" name="registrations">
                            <field name="registration_ids">
                                <list>
                                    <field name="term_id"/>
                                    <field name="course_id"/>
                                    <field name="section_id"/>
                                    <field name="credit_hours"/>
                                    <field name="grade_letter"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Holds" name="holds">
                            <field name="hold_ids">
                                <list editable="bottom">
                                    <field name="hold_type"/>
                                    <field name="reason"/>
                                    <field name="blocks_registration"/>
                                    <field name="active"/>
                                    <button name="action_clear" type="object"
                                            string="Clear" icon="fa-check"
                                            invisible="not active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Advising Notes" name="advising">
                            <field name="advising_note_ids">
                                <list editable="bottom">
                                    <field name="note_date"/>
                                    <field name="advisor_id"/>
                                    <field name="subject"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Academic Standing" name="standing">
                            <field name="standing_ids">
                                <list>
                                    <field name="term_id"/>
                                    <field name="cgpa"/>
                                    <field name="standing" widget="badge"/>
                                </list>
                            </field>
                        </page>
                        <page string="Status History" name="status_history">
                            <field name="status_history_ids">
                                <list>
                                    <field name="effective_date"/>
                                    <field name="old_status"/>
                                    <field name="new_status"/>
                                    <field name="reason"/>
                                    <field name="changed_by"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_ums_student_search" model="ir.ui.view">
        <field name="name">ums.student.search</field>
        <field name="model">ums.student</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="university_id"/>
                <field name="national_id"/>
                <field name="program_id"/>
                <filter name="active_students" string="Active" domain="[('status', '=', 'active')]"/>
                <filter name="with_holds" string="With Holds" domain="[('active_hold_count', '>', 0)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_program" string="Program" context="{'group_by': 'program_id'}"/>
                    <filter name="group_status" string="Status" context="{'group_by': 'status'}"/>
                    <filter name="group_level" string="Level" context="{'group_by': 'level'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ums_student" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">ums.student</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active_students': 1}</field>
    </record>
</odoo>
