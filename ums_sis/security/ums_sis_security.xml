<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="ums_group_student" model="res.groups">
        <field name="name">UMS: Student</field>
    </record>

    <record id="ums_group_advisor" model="res.groups">
        <field name="name">Academic: Advisor</field>
