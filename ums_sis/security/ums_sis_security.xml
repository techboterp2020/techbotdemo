<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="ums_group_student" model="res.groups">
        <field name="name">UMS: Student</field>
        <field name="category_id" ref="ums_core.module_category_ums"/>
        <field name="comment">Self-service: register, view own schedule/grades/holds.</field>
    </record>

    <record id="ums_group_advisor" model="res.groups">
        <field name="name">Academic: Advisor</field>
        <field name="category_id" ref="ums_core.module_category_ums"/>
        <field name="implied_ids" eval="[(4, ref('ums_core.ums_group_academic_user'))]"/>
        <field name="comment">Approve registration, manage holds and advising notes for advisees.</field>
    </record>

    <record id="ums_core.ums_group_dept_head" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('ums_group_advisor'))]"/>
    </record>

</odoo>
